# KIS Open API
KIS_APPKEY=your_appkey_here
KIS_SECRETKEY=your_secretkey_here
KIS_ACCOUNT_NO=12345678-01
KIS_ENV=real

# Market Data Provider
# kis: 기존 KIS 경로 유지
# toss: Toss OpenAPI로 시세/환율/OHLCV 조회
MARKET_DATA_PROVIDER=kis

# Toss Invest OpenAPI
TOSS_CLIENT_ID=your_toss_client_id_here
TOSS_CLIENT_SECRET=your_toss_client_secret_here
TOSS_ACCOUNT_SEQ=your_toss_account_seq_here
TOSS_HOLDINGS_SYNC_ENABLED=false
TOSS_HOLDINGS_SYNC_INTERVAL_MINUTES=60

# FMP (Phase β)
FMP_API_KEY=your_fmp_key_here

# Gemini AI
GEMINI_API_KEY=your_gemini_key_here

# Basic Auth (deprecated — JWT로 대체됨)
# BASIC_AUTH_USERNAME=admin
# BASIC_AUTH_PASSWORD=changeme

# JWT 인증 (필수)
JWT_SECRET=change-me-to-a-random-32-byte-string
JWT_ALG=HS256
JWT_TTL_MIN=10080

# 기존 DB 마이그레이션용 LEGACY 계정 (첫 실행 시 user_id=1로 자동 생성)
LEGACY_USER_EMAIL=your@email.com
LEGACY_USER_PASSWORD=changeme

# 회원가입 허용 여부 (운영 서버에서는 false로 잠금 가능)
ALLOW_SIGNUP=true

# 쿠키 Secure 플래그 (HTTPS 운영에서는 true)
COOKIE_SECURE=false

# 외부 스프레드시트용 읽기 전용 포트폴리오 API
PORTFOLIO_EXPORT_API_KEY=change-me-to-a-long-random-string

# 앱
DB_PATH=data/dudunomics.duckdb
DEBUG=false
PORT=8888
ALLOWED_ORIGINS=http://localhost:3333
